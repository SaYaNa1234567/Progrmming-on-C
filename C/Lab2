#include <stdio.h>
#include <stdlib.h>

int main() {
	double matrix[3][3];
	int i, j;
	printf("Matrix:\n");
	double main_diag, pob_diag;
	
	for (i = 0; i < 3; i++) {
		for (j = 0; j < 3; j++) {
			printf("	matrix[%d][%d] = ", i, j);
			scanf("%lf", &matrix[i][j]);
		}
		printf("\n");
	}
	for (i = 0; i < 3; i++) {
		for (j = 0; j < 3; j++) {
			printf("%.2lf ", matrix[i][j]);
		}
		printf("\n");
	}
	
	for (i = 0; i<3; i++){
		main_diag = main_diag + matrix[i][i];
		
		pob_diag = pob_diag + matrix[i][2 - i];
	}
	printf("\nSumm main diag = %.2lf\n", main_diag);
	printf("Summ poboch diag = %.2lf\n", pob_diag);
	return 0;
}
